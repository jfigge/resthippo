# wurl — shared local dev environment
#
# Copy this file to `dev.env` (git-ignored) and edit. The Makefile -includes it
# and exports the values, so `make debug`, `make launch`, and `make mock-up`
# all see the SAME settings.
#
#   cp dev.env.example dev.env
#
# Precedence: `make VAR=value` (one-off) > dev.env > your shell environment >
# the Makefile defaults. Lines are plain KEY=value (no `export`, no quotes).

# ── Ports ─────────────────────────────────────────────────────────────────────
# Honored by the Go mock server (make mock-up). The app does not read these.
MOCK_PORT=8888
MOCK_PROXY_PORT=9999
MOCK_SOCKS_PORT=9998

# ── Proxy auth (opt-in) ───────────────────────────────────────────────────────
# When either is set, the mock's forward + SOCKS5 proxies require these
# credentials. In the app, enter the same values in Settings → Proxy, or
# reference them in a request via the env() variable function, e.g.
#   {{env('MOCK_PROXY_USER')}}
MOCK_PROXY_USER=
MOCK_PROXY_PASS=

# ── App dev server ────────────────────────────────────────────────────────────
# Port the Electron app reads (process.env.SERVER_PORT) when pointed at the Go
# dev server rather than the bundled renderer. Leave blank to use the default.
SERVER_PORT=
