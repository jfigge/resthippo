# ── Build outputs ─────────────────────────────────────────────────────────────
build/
dist/
data/
certs/
data.backup/
data-docs/
.docs-build/
.keys/

# ── E2E runtime data (seeded per run; the suite itself is tracked) ─────────────
e2e/.data/

# ── Node / npm ────────────────────────────────────────────────────────────────
src/node_modules/
src/npm-debug.log*
.npm

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
.keys

# ── Editor / IDE ──────────────────────────────────────────────────────────────
*.swp
.vscode/

# ── Electron builder cache ────────────────────────────────────────────────────
.electron-builder-cache/

# ── Mock server ───────────────────────────────────────────────────────────────
mock/mock-server
mock/.mock.pid
mock/.mock.log

# ── Local dev environment (shared by make debug / launch / mock-up) ───────────
# Tracked template lives in dev.env.example; the real file stays local.
dev.env

# ── Release signing credentials (used by dist-mac / dist-win) ─────────────────
# Tracked template lives in release.env.example; the real file holds signing
# secrets (Developer ID p12, Apple notarization creds, Authenticode pfx) and
# stays local. CI supplies the same values from repository secrets instead.
release.env

# Raw signing material — Developer ID certs/keys, Apple notarization API .p8,
# Authenticode .pfx. These are SECRETS; never commit them.
keys/
*.p8
*.p12
*.pfx

# Mac App Store provisioning profiles (per-developer, embed a team-specific cert)
# dropped into src/packaging for `make dist-mas` / `mas-dev`. Never commit them.
*.provisionprofile

# ── Data and local test files ─────────────────────────────────────────────────
data/collections.json
features/
CLAUDE.md

# ── Docs screenshot originals ─────────────────────────────────────────────────
# Full-resolution PNGs from the .docs-build pipeline. The copies bundled under
# src/web/docs/images are downscaled 50%; these originals stay local.
docs-originals/

# ── Website build artifacts ───────────────────────────────────────────────────
# Generated at deploy time (and in the Deploy Website workflow); never hand-edited.
#   versions.json     ← scripts/build-versions.mjs (GitHub Releases API)
#   docs/, sitemap.xml ← scripts/build-docs.mjs (renders src/web/docs/*.md)
website/versions.json
website/docs/
website/sitemap.xml
