# ── Build outputs ─────────────────────────────────────────────────────────────
build/
dist/
data/
data.backup/
data-docs/
.docs-build/

# ── Node / npm ────────────────────────────────────────────────────────────────
src/node_modules/
src/npm-debug.log*
.npm

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editor / IDE ──────────────────────────────────────────────────────────────
*.swp
.vscode/

# ── Electron builder cache ────────────────────────────────────────────────────
.electron-builder-cache/

# ── Mock server ───────────────────────────────────────────────────────────────
mock/mock-server
mock/.mock.pid
mock/.mock.log

# ── Local dev environment (shared by make debug / launch / mock-up) ───────────
